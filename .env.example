# Port the service listens on
HTTP_PORT=8080

# Shared Docker network for docker-compose. Set to the network that your
# Postgres + Sonarr containers already share so animelisterr can reach
# them by container name.
NETWORK_NAME=bridge

# Postgres connection. Special characters in DB_PASS are fine — the app
# percent-encodes values when building the DSN.
#
# Defaults (all optional): host=localhost, port=5432, user=postgres,
# pass=postgres, name=animelisterr, sslmode=disable. Override any subset.
#DB_HOST=localhost
#DB_PORT=5432
#DB_USER=postgres
#DB_PASS=postgres
#DB_NAME=animelisterr
#DB_SSLMODE=disable

# Sonarr used as a TVDB-lookup proxy via /api/v3/series/lookup (required)
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=your-sonarr-api-key

# How often to re-pull the ranking feed (optional, default 1h)
#REFRESH_INTERVAL=1h

# Max number of regular (non-special) seasons a show may have to appear
# in /sonarr/list. 1 = single-season only (default); 2 includes shows
# with one sequel; 0 or negative disables the filter entirely.
#MAX_SEASON_COUNT=1

# How many of the weekly top-ranked entries to scrape and consider.
# Anime Corner publishes a full top-30 each week; the default of 10
# matches the original product rule. 0 or negative = include the whole
# ranking.
#TOP_N=10
